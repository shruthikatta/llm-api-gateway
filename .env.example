APP_NAME=LLM API Gateway

APP_ENV=development

HOST=0.0.0.0
PORT=8000

LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://gateway_user:gateway_password@localhost:5432/ai_gateway

REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

JWT_SECRET=change-me-in-development

# Optional: Slack incoming webhook for operational alerts (Phase 5)
SLACK_WEBHOOK_URL=

DEFAULT_PROVIDER=openai

DEFAULT_MODEL=gpt-4.1-mini

GATEWAY_CONFIG_PATH=config/gateway.yaml
